RESEND_API_KEY=
CONTACT_EMAIL_TO=hola@dinkbit.com
CONTACT_EMAIL_FROM="dinkbit <onboarding@resend.dev>"
NEXT_PUBLIC_GTM_ID=
# Solo necesaria para /imagina-tu-web (preview con IA).
# Crear cuenta en platform.openai.com y cargar saldo (>=$5).
OPENAI_API_KEY=

# --- Panel interno de leads (/panel) — Supabase + login ---
# Proyecto Supabase "dinkbit-leads" (ref wnboyesnlrbtwfmhcxmc): Project Settings -> API
SUPABASE_URL=https://wnboyesnlrbtwfmhcxmc.supabase.co
# service_role (SECRETA, server-only). NUNCA exponer en el cliente.
SUPABASE_SERVICE_ROLE_KEY=
# Acceso al panel (usuario/contraseña compartida) + secreto para firmar la cookie.
PANEL_USER=
PANEL_PASS=
PANEL_SECRET=

# --- Webhook de entrada de leads (POST /api/leads) ---
# Secreto compartido que debe enviar Zapier (header x-webhook-secret).
# Genera uno con: openssl rand -hex 24
LEADS_WEBHOOK_SECRET=

# --- Calculadora del panel (/panel/calculadora) ---
# OPCIONALES: si se configuran, lee el catálogo de servicios EN VIVO de la
# plataforma financiera (proyecto Supabase khathnaehiqchjjfmrqk). Si se dejan
# vacías, usa el snapshot incrustado en el código.
FINANCE_SUPABASE_URL=
FINANCE_SUPABASE_SERVICE_ROLE_KEY=

# Mailchimp — alta de emails de la promo en la audiencia (single opt-in)
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=us12
# Firma HMAC de los tokens del cuestionario de la promo. Si falta, cae a RESEND_API_KEY.
PROMO_TOKEN_SECRET=
